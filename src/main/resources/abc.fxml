<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/19"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.personal.controlr.ControlR">

   <children>
      <Button fx:id="hibtn" layoutX="105.0" layoutY="256.0" mnemonicParsing="false" onAction="#sayHi" text="Hi" />
      <Button fx:id="byebtn" layoutX="310.0" layoutY="256.0" mnemonicParsing="false" onAction="#sayBye" text="Bye" />
   </children>

</AnchorPane>
